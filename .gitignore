# --- OS & IDE ---
.DS_Store
.vscode/
.idea/

# --- Env & Secrets (Security) ---
.env
.env.*
*/.env
**/ .env
*.pem
*.key

# --- Frontend (React Native / Expo) ---
# 아래 항목들은 모든 폴더 내의 해당 이름을 가진 폴더를 무시합니다.
node_modules/
.expo/
dist/
web-build/
expo-env.d.ts
*.tsbuildinfo
.metro-health-check*

# 만약 ios/android 폴더가 frontend 폴더 안에 있다면 아래와 같이 적습니다.
frontend/ios/
frontend/android/
*.jks
*.p8
*.p12
*.mobileprovision

# --- Backend (Python / FastAPI) ---
backend/venv/
backend/__pycache__/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Debug logs ---
npm-debug.*
yarn-debug.*
yarn-error.*
pip-log.txt